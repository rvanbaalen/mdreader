{
  "name": "mdreader",
  "version": "1.0.3",
  "description": "A beautiful macOS markdown reader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:zip": "electron-builder --mac zip --publish never"
  },
  "author": "Robin van Baalen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rvanbaalen/mdreader.git"
  },
  "build": {
    "appId": "com.rvanbaalen.mdreader",
    "productName": "mdreader",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "identity": null,
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "mdreader",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "renderer.js",
      "node_modules/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "rvanbaalen",
        "repo": "mdreader"
      }
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "role": "Viewer"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "role": "Viewer"
      }
    ]
  },
  "dependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.6.2",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  }
}
